# Pacific Golf Web - Environment Variables

# API URL
VITE_API_URL=http://localhost:3000

# Clerk Authentication
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
# JWT template used for admin API auth (must include email claim)
VITE_CLERK_JWT_TEMPLATE=giaa-tournament

# Stripe Payments
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# WebSocket URL (ActionCable)
VITE_WS_URL=ws://localhost:3000/cable
VITE_ENABLE_DEV_AUTH_BYPASS=false

# Legacy Registration URL (optional)
# Used by /legacy "Register Now" button. If unset, button is disabled.
# VITE_LEGACY_REGISTER_URL=https://legacy-registration-url.com
