# Pacific Golf API - Environment Variables

# Database
DATABASE_URL=postgresql://localhost/pacific_golf_development

# Redis (for ActionCable)
REDIS_URL=redis://localhost:6379/1

# Clerk Authentication
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# Stripe Payments
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend Email
RESEND_API_KEY=re_...

# Frontend URL (for CORS, emails)
FRONTEND_URL=http://localhost:5173

# Rails
RAILS_ENV=development
RAILS_MASTER_KEY=
ENABLE_RATE_LIMITING=false
ACCESS_REQUEST_NOTIFY_EMAIL=shimizutechnology@gmail.com
ENABLE_DEV_AUTH_BYPASS=false
BOOTSTRAP_SUPER_ADMIN_EMAIL=
BOOTSTRAP_SUPER_ADMIN_NAME=
BOOTSTRAP_SUPER_ADMIN_CLERK_ID=

# Active Storage (set ACTIVE_STORAGE_SERVICE=amazon to force S3 in development)
ACTIVE_STORAGE_SERVICE=

# AWS S3 (Active Storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
# Backward-compatible fallback (prefer AWS_S3_BUCKET)
AWS_BUCKET=
