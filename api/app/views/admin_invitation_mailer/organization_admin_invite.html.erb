<div style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; color: #1f2937; line-height: 1.5;">
  <h2 style="margin: 0 0 12px; color: #0f172a;">You're invited to Pacific Golf</h2>

  <p style="margin: 0 0 12px;">
    <strong><%= @invited_by&.name.presence || @invited_by&.email %></strong> invited you to manage
    <strong><%= @organization.name %></strong>.
  </p>

  <p style="margin: 0 0 12px;">
    If this is your first time, use the same email address and click <strong>Sign up</strong> on the admin login screen.
    If you already have an account, just sign in.
  </p>

  <p style="margin: 20px 0;">
    <a
      href="<%= @admin_login_url %>"
      style="display:inline-block; background:#16a34a; color:#ffffff; text-decoration:none; padding:10px 16px; border-radius:8px; font-weight:600;"
    >
      Go to Admin Login
    </a>
  </p>

  <p style="margin: 0 0 8px; color: #4b5563;">
    Organization: <strong><%= @organization.name %></strong> (<%= @organization.slug %>)
  </p>

  <p style="margin: 0; color: #6b7280; font-size: 13px;">
    If you were not expecting this invite, you can ignore this email.
  </p>
</div>
